{
  "name": "ai-office-pixel-office",
  "version": "0.1.0",
  "description": "AI Office Pixel Office — real-time agent visualization",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "npx tsx watch server/index.ts",
    "dev:client": "vite --config vite.config.ts",
    "build:server": "npx tsc -p tsconfig.server.json",
    "build:client": "vite build client",
    "build": "npm run build:server && npm run build:client",
    "start": "node dist/server/index.js"
  },
  "dependencies": {
    "@ngrok/ngrok": "^1.7.0",
    "better-sqlite3": "^11.6.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.0",
    "express": "^4.21.0",
    "phaser": "^3.87.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.9.0",
    "concurrently": "^9.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.3",
    "vite": "^6.0.0"
  }
}
